NODE_ENV=development
PORT=8787
TRUST_PROXY=false
CONTACT_ALLOWED_ORIGINS=http://localhost:5173
CONTACT_RECIPIENT=your-recipient@example.com
CONTACT_FROM=your-sender@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your_app_password_here
CONTACT_RATE_LIMIT_WINDOW_MS=60000
CONTACT_RATE_LIMIT_MAX=8
AUTO_REPLY_ENABLED=true
AUTO_REPLY_SUBJECT=Thanks for reaching out — I received your message!
AUTO_REPLY_BODY=Hi there,\n\nThanks for contacting me! I’ve received your message and will get back to you as soon as possible.\n\nBest,\nPortfolio
BLOG_GITHUB_OWNER=your-github-username
BLOG_GITHUB_REPO=blog
BLOG_GITHUB_BRANCH=main
# Use either:
# - content/blog-posts.json (JSON array mode)
# - content/posts (Markdown directory mode with frontmatter)
BLOG_GITHUB_PATH=content/blog-posts.json
BLOG_GITHUB_TOKEN=your_github_fine_grained_token
BLOG_CACHE_TTL_MS=300000
VITE_BLOG_SOURCE=api
VITE_BLOG_GITHUB_OWNER=
VITE_BLOG_GITHUB_REPO=
VITE_BLOG_GITHUB_BRANCH=main
VITE_BLOG_GITHUB_PATH=content/blog-posts.json
